# =============================================================
# Agental.IA — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# =============================================================

# Supabase
# Ve a: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...  # anon public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...      # service_role key (secreta — NUNCA en el cliente)

# NextAuth
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=tu_secreto_super_largo_aqui
NEXTAUTH_URL=http://localhost:3000
# En producción: NEXTAUTH_URL=https://tu-dominio.vercel.app

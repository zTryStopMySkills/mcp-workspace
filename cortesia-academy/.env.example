# CortesIA Academy — variables de entorno
# Copiar como .env.local y rellenar

# Supabase (compartido con agental-ia-web para reutilizar tabla agents)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# NextAuth
NEXTAUTH_SECRET=genera_con_openssl_rand_base64_32
NEXTAUTH_URL=https://academy.cortesia.ai

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# LiveKit (F2 — videollamadas)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Resend (email transaccional)
RESEND_API_KEY=re_...
